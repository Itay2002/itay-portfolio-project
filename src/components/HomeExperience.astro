---
import { ArrowUpRight, Search, Sparkles } from "@lucide/astro";
import { identity, pages } from "@/content/siteContent";

const accentValues = {
  blue: "var(--blue)",
  emerald: "var(--emerald)",
  gold: "var(--gold)"
};
---

<main class="shell hero" data-home-experience>
  <section aria-labelledby="home-title">
    <p class="eyebrow">{identity.position}</p>
    <p class="scene-label">{identity.welcomeLine}</p>
    <h1 id="home-title">{identity.movieLine}</h1>
    <div class="identity-row">
      <span>{identity.name}</span>
      <span class="dot" aria-hidden="true"></span>
      <span>{identity.location}</span>
      <span class="dot" aria-hidden="true"></span>
      <span>{identity.roleLine}</span>
    </div>
    <p class="promise">{identity.promise}</p>
  </section>

  <section class="deck" aria-label="Portfolio worlds">
    <label class="command">
      <Search aria-hidden="true" />
      <input data-world-filter type="search" placeholder="search the movie" autocomplete="off" />
    </label>

    <div class="world-grid" data-world-grid>
      {
        pages.map((page, index) => (
          <a
            class={`world-card ${index === 0 ? "is-active" : ""}`}
            href={`/${page.slug}`}
            data-world-card
            data-title={page.title}
            data-kicker={page.kicker}
            data-accent={page.accent}
            style={`--card-accent: ${accentValues[page.accent]}`}
          >
            <span class="world-card__kicker">{page.kicker}</span>
            <span class="world-card__title">
              {page.title}
              <ArrowUpRight aria-hidden="true" />
            </span>
          </a>
        ))
      }
    </div>

    <aside class="preview" aria-live="polite">
      <p class="eyebrow">active signal</p>
      <h2 data-preview-title>{pages[0].title}</h2>
      <p class="preview__status" data-preview-status>
        <Sparkles aria-hidden="true" /> This scene is intentionally open. Hover, focus, or search to choose where the movie goes next.
      </p>
    </aside>
  </section>
</main>

<script>
  const root = document.querySelector("[data-home-experience]");
  const cards = [...document.querySelectorAll("[data-world-card]")] as HTMLAnchorElement[];
  const filter = document.querySelector("[data-world-filter]") as HTMLInputElement | null;
  const previewTitle = document.querySelector("[data-preview-title]") as HTMLElement | null;
  const previewStatus = document.querySelector("[data-preview-status]") as HTMLElement | null;

  const accentMap: Record<string, string> = {
    blue: "var(--blue)",
    emerald: "var(--emerald)",
    gold: "var(--gold)"
  };

  function activate(card: HTMLAnchorElement | null) {
    if (!card || !previewTitle || !previewStatus) return;
    cards.forEach((item) => item.classList.toggle("is-active", item === card));
    const accent = card.dataset.accent || "blue";
    document.documentElement.style.setProperty("--accent", accentMap[accent] || accentMap.blue);
    previewTitle.textContent = card.dataset.title || "";
    previewStatus.textContent = `${card.dataset.kicker || "signal"} is ready for your next pass. This scene is blank for now.`;
  }

  for (const card of cards) {
    card.addEventListener("mouseenter", () => activate(card));
    card.addEventListener("focus", () => activate(card));
  }

  filter?.addEventListener("input", () => {
    const query = filter.value.trim().toLowerCase();
    let firstVisible: HTMLAnchorElement | null = null;

    for (const card of cards) {
      const haystack = `${card.dataset.title} ${card.dataset.kicker}`.toLowerCase();
      const visible = haystack.includes(query);
      card.hidden = !visible;
      if (visible && !firstVisible) firstVisible = card;
    }

    if (firstVisible) {
      activate(firstVisible);
    } else if (previewTitle && previewStatus) {
      previewTitle.textContent = "no signal found";
      previewStatus.textContent = "Try another word from the portfolio map.";
    }
  });

  window.addEventListener("pointermove", (event) => {
    document.documentElement.style.setProperty("--cursor-x", `${event.clientX}px`);
    document.documentElement.style.setProperty("--cursor-y", `${event.clientY}px`);
  });

  root?.addEventListener("keydown", (event: Event) => {
    if (!(event instanceof KeyboardEvent)) return;
    if (event.key !== "ArrowDown" && event.key !== "ArrowUp") return;
    const visibleCards = cards.filter((card) => !card.hidden);
    const activeElement = document.activeElement;
    if (!(activeElement instanceof HTMLAnchorElement)) return;
    const index = visibleCards.indexOf(activeElement);
    if (index === -1) return;
    event.preventDefault();
    const direction = event.key === "ArrowDown" ? 1 : -1;
    const next = visibleCards[(index + direction + visibleCards.length) % visibleCards.length];
    next?.focus();
  });
</script>
