---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { pages, type PortfolioPage } from "@/content/siteContent";

export function getStaticPaths() {
  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

type Props = {
  page: PortfolioPage;
};

const { page } = Astro.props;
---

<BaseLayout title={`${page.title} | Itay Gozalzani`}>
  <main class="shell page-shell">
    <p class="eyebrow">{page.kicker}</p>
    <h1>{page.title}</h1>
    <div class="page-empty">
      <p>This scene is intentionally blank for now. It already has a stable route, navigation entry, and content slots so future context can land cleanly.</p>
      <ul class="future-slots" aria-label="Future content slots">
        {page.futureContent.map((slot) => <li>{slot}</li>)}
      </ul>
    </div>
  </main>
</BaseLayout>
